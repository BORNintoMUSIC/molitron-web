# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# local worktrees and scratch output
/.worktrees/
/tmp/

# private controlled source records
/docs/Certifications/

# generated technical-document working artifacts
/docs/PDF_Rebuild/**/build/
/docs/PDF_Rebuild/**/__pycache__/

# raw customer logo sources; publish only optimized derivatives
/public/images/previous-customers/*/
!/public/images/previous-customers/optimized/
!/public/images/previous-customers/optimized/**
